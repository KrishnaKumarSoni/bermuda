{
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb"
      }
    },
    {
      "src": "frontend/index.html", 
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/simple",
      "dest": "/api/simple.py"
    },
    {
      "src": "/api/infer-async",
      "dest": "/api/infer-async.py"
    },
    {
      "src": "/api/status/([^/]+)",
      "dest": "/api/infer-async.py"
    },
    {
      "src": "/api/infer",
      "dest": "/api/infer.py"
    },
    {
      "src": "/form/(.*)",
      "dest": "frontend/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/index.html"
    }
  ],
  "env": {
    "PYTHONPATH": "$PYTHONPATH:./api"
  }
}