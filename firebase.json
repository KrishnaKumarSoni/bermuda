{
  "hosting": {
    "public": "frontend",
    "rewrites": [
      {
        "source": "/f/**",
        "destination": "/app.html"
      },
      {
        "source": "/form/**",
        "destination": "/app.html"
      },
      {
        "source": "/app",
        "destination": "/app.html"
      },
      {
        "source": "/app/**",
        "destination": "/app.html"
      }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate, max-age=0"
          },
          {
            "key": "Pragma", 
            "value": "no-cache"
          },
          {
            "key": "Expires",
            "value": "0"
          },
          {
            "key": "ETag",
            "value": "\"v2025072202\""
          }
        ]
      }
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ]
  },
  "functions": {
    "source": "api",
    "runtime": "python311"
  }
}