{
  "functions": {
    "source": "api",
    "runtime": "python311"
  },
  "hosting": {
    "public": "frontend",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api"
      },
      {
        "source": "/dashboard",
        "destination": "/app.html"
      },
      {
        "source": "/app",
        "destination": "/app.html"
      },
      {
        "source": "/form/**",
        "destination": "/app.html"
      },
      {
        "source": "/",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "indexes": "firestore.indexes.json"
  }
}